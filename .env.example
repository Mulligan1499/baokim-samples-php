# Baokim B2B API Configuration
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git

# Base URL
# - Dev/Test: https://devtest.baokim.vn
# - Production: https://openapi.baokim.vn
BAOKIM_BASE_URL=https://devtest.baokim.vn
BAOKIM_TIMEOUT=30

# Merchant credentials
BAOKIM_MERCHANT_CODE=
BAOKIM_CLIENT_ID=
BAOKIM_CLIENT_SECRET=

# Master/Sub Merchant
BAOKIM_MASTER_MERCHANT_CODE=
BAOKIM_SUB_MERCHANT_CODE=

# Direct Connection credentials (không qua Master Merchant)
BAOKIM_DIRECT_MERCHANT_CODE=
BAOKIM_DIRECT_CLIENT_ID=
BAOKIM_DIRECT_CLIENT_SECRET=

# Callback URLs
BAOKIM_URL_SUCCESS=https://your-domain.com/payment/success
BAOKIM_URL_FAIL=https://your-domain.com/payment/fail
BAOKIM_WEBHOOK_URL=https://your-domain.com/webhook/baokim
